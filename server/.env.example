DATABASE_URL=postgres://postgres:postgres@localhost:5432/travel
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
# Override only if host port 5432 is taken locally. Keep DATABASE_URL's port in sync.
# POSTGRES_HOST_PORT=5433

# Optional. When set, the server makes one OpenRouter call after the solver
# to add a day theme and a one-line blurb per activity. Itinerary works
# without it — those fields just stay absent.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini
